{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Signal Schedule Shift Trades UI Read Preview",
  "type": "object",
  "required": [
    "meta",
    "requests",
    "rules"
  ],
  "properties": {
    "meta": {
      "type": "object"
    },
    "requests": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "type",
          "status",
          "fromEmployee",
          "date",
          "time",
          "coverageImpact",
          "eligibility"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "fromEmployee": {
            "type": "string"
          },
          "toEmployee": {
            "type": "string"
          },
          "date": {
            "type": "string"
          },
          "time": {
            "type": "string"
          },
          "coverageImpact": {
            "type": "string"
          },
          "eligibility": {
            "type": "string"
          },
          "employeeAcceptance": {
            "type": "string"
          },
          "supervisorDecision": {
            "type": "string"
          },
          "assignmentEngineHook": {
            "type": "string"
          }
        }
      }
    },
    "workflowStages": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
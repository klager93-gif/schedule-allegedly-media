{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schedule.allegedly-media.com/contracts/training-certifications.read.schema.json",
  "title": "Training Certifications Read Contract",
  "type": "object",
  "required": ["summary", "records"],
  "properties": {
    "summary": {
      "type": "object",
      "properties": {
        "totalRecords": { "type": "integer" },
        "expiringSoon": { "type": "integer" },
        "expired": { "type": "integer" },
        "inTraining": { "type": "integer" },
        "restricted": { "type": "integer" }
      }
    },
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "employee", "role", "credential", "status", "scheduleImpact"],
        "properties": {
          "id": { "type": "string" },
          "employee": { "type": "string" },
          "role": { "type": "string" },
          "credential": { "type": "string" },
          "status": { "type": "string" },
          "expiresOn": { "type": ["string", "null"] },
          "daysRemaining": { "type": ["integer", "null"] },
          "scheduleImpact": { "type": "string" },
          "adminAction": { "type": "string" }
        }
      }
    }
  }
}

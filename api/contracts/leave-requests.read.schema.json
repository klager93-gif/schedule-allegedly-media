{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Signal Schedule Leave Requests Read Contract",
  "type": "object",
  "required": [
    "types",
    "requests"
  ],
  "properties": {
    "types": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "label"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "paid": {
            "type": "boolean"
          },
          "requiresApproval": {
            "type": "boolean"
          }
        }
      }
    },
    "requests": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "employeeId",
          "employeeName",
          "type",
          "startDate",
          "endDate",
          "status"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "employeeId": {
            "type": "string"
          },
          "employeeName": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "startDate": {
            "type": "string",
            "format": "date"
          },
          "endDate": {
            "type": "string",
            "format": "date"
          },
          "status": {
            "enum": [
              "pending",
              "approved",
              "denied",
              "cancelled"
            ]
          },
          "fullDay": {
            "type": "boolean"
          },
          "startTime": {
            "type": "string"
          },
          "endTime": {
            "type": "string"
          },
          "calculatedHours": {
            "type": "number"
          },
          "scheduledShiftHours": {
            "type": "number"
          },
          "minimumIncrementMinutes": {
            "type": "integer"
          },
          "incrementOverrideUsed": {
            "type": "boolean"
          },
          "incrementOverrideReason": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "incrementSettings": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  }
}

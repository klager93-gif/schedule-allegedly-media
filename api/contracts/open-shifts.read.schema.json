{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Signal Schedule Open Shifts Read Contract",
  "version": "v2.4.0",
  "type": "object",
  "required": [
    "openShifts",
    "votRequests",
    "requestReasons"
  ],
  "properties": {
    "openShifts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "date",
          "assignment",
          "startTime",
          "endTime",
          "hours",
          "coverageStatus"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "date": {
            "type": "string"
          },
          "assignment": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "shiftName": {
            "type": "string"
          },
          "startTime": {
            "type": "string"
          },
          "endTime": {
            "type": "string"
          },
          "hours": {
            "type": "number"
          },
          "coverageStatus": {
            "type": "string"
          }
        }
      }
    },
    "votRequests": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "requestReasons": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  }
}

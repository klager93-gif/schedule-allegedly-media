{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schedule.allegedly-media.com/api/contracts/daily-board.read.schema.json",
  "title": "Signal Schedule Daily Board Read Contract",
  "type": "object",
  "required": ["summary", "days", "rules"],
  "properties": {
    "summary": { "type": "object" },
    "filters": { "type": "object" },
    "days": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["date", "label", "agencies"],
        "properties": {
          "date": { "type": "string" },
          "label": { "type": "string" },
          "agencies": { "type": "array" }
        }
      }
    },
    "rules": { "type": "array", "items": { "type": "string" } }
  }
}

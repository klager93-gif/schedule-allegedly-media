{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Signal Schedule Shift Eligibility Read Model",
  "type": "object",
  "required": [
    "summary",
    "requirements",
    "checks"
  ],
  "properties": {
    "summary": {
      "type": "object"
    },
    "policyChecks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "requirements": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "requiredCredential",
          "allowOverride"
        ]
      }
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "source",
          "shift",
          "requiredCredential",
          "employee",
          "employeeCredentialStatus",
          "result",
          "reason"
        ]
      }
    }
  }
}
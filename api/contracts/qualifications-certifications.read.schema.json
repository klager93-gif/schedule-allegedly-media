{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Signal Schedule Qualifications & Certifications Read Contract",
  "type": "object",
  "required": ["meta", "summary", "qualificationTypes", "employeeCredentials", "roleRequirements", "rolePanels", "rules"],
  "properties": {
    "meta": { "type": "object" },
    "summary": { "type": "object" },
    "policyProfile": { "type": "object" },
    "qualificationTypes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "licenseNumberRequirement"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "category": { "type": "string" },
          "requiredForRoles": { "type": "array", "items": { "type": "string" } },
          "licenseNumberRequirement": { "type": "string", "enum": ["not_required", "optional", "required"] },
          "expirationRequired": { "type": "boolean" },
          "defaultWarningDays": { "type": "number" },
          "notes": { "type": "string" }
        }
      }
    },
    "employeeCredentials": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "employeeId", "employeeName", "qualification", "status"],
        "properties": {
          "id": { "type": "string" },
          "employeeId": { "type": "string" },
          "employeeName": { "type": "string" },
          "qualification": { "type": "string" },
          "status": { "type": "string" },
          "issueDate": { "type": ["string", "null"] },
          "expirationDate": { "type": ["string", "null"] },
          "daysUntilExpiration": { "type": ["number", "null"] },
          "licenseNumber": { "type": ["string", "null"] },
          "certificateNumber": { "type": ["string", "null"] },
          "issuingAuthority": { "type": ["string", "null"] },
          "notes": { "type": ["string", "null"] },
          "visibility": { "type": "string" }
        }
      }
    },
    "roleRequirements": { "type": "array", "items": { "type": "object" } },
    "expirationWarnings": { "type": "array", "items": { "type": "object" } },
    "integrationChecks": { "type": "array", "items": { "type": "object" } },
    "rolePanels": { "type": "array", "items": { "type": "object" } },
    "rules": { "type": "array", "items": { "type": "string" } }
  }
}

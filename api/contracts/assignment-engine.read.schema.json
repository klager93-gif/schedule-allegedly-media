{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tools.allegedly-media.com/schedule/api/contracts/assignment-engine.read.schema.json",
  "title": "Signal Schedule Assignment Engine Read Contract",
  "type": "object",
  "required": ["summary", "filters", "records", "sourceTypes", "history", "rules"],
  "properties": {
    "summary": { "type": "object" },
    "filters": { "type": "object" },
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "date", "agencyId", "shiftId", "role", "spotCode", "source", "status", "coverageImpact"],
        "properties": {
          "id": { "type": "string" },
          "date": { "type": "string" },
          "agencyId": { "type": "string" },
          "agency": { "type": "string" },
          "shiftId": { "type": "string" },
          "shift": { "type": "string" },
          "time": { "type": "string" },
          "role": { "type": "string" },
          "spotCode": { "type": "string" },
          "spotLabel": { "type": "string" },
          "employeeId": { "type": ["string", "null"] },
          "employee": { "type": ["string", "null"] },
          "source": { "type": "string" },
          "status": { "type": "string" },
          "coverageImpact": { "type": "string" },
          "relatedRecordId": { "type": ["string", "null"] },
          "notes": { "type": "string" }
        }
      }
    },
    "sourceTypes": { "type": "array" },
    "history": { "type": "array" },
    "rules": { "type": "array", "items": { "type": "string" } }
  }
}

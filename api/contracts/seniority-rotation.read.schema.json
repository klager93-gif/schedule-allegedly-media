{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Signal Schedule Seniority Rotation Read Model",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "rank": {
      "type": "integer"
    },
    "employeeName": {
      "type": "string"
    },
    "employeeCode": {
      "type": "string"
    },
    "status": {
      "enum": [
        "eligible",
        "skipped",
        "mandate"
      ]
    },
    "listType": {
      "enum": [
        "callback",
        "mandate",
        "overtime"
      ]
    },
    "scenario": {
      "type": "string"
    },
    "seniorityDate": {
      "type": "string"
    },
    "equalizedOtHours": {
      "type": "number"
    },
    "mandatesYtd": {
      "type": "integer"
    },
    "callbacksYtd": {
      "type": "integer"
    },
    "lastOffered": {
      "type": "string"
    },
    "qualifications": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "recommendation": {
      "type": "string"
    },
    "skipReason": {
      "type": "string"
    }
  },
  "required": [
    "id",
    "rank",
    "employeeName",
    "status"
  ]
}
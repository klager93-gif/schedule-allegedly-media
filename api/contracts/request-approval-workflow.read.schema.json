{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Signal Schedule Request Approval Workflow Preview",
  "type": "object",
  "required": [
    "summary",
    "queues",
    "requests",
    "chains",
    "policyChecks"
  ],
  "properties": {
    "summary": {
      "type": "object"
    },
    "queues": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "requests": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "chains": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "policyChecks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}